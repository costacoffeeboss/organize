{
  "expo": {
    "name": "Organize",
    "slug": "organize",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "runtimeVersion": "1.1.0",
    "updates": {
      "checkAutomatically": "ON_LOAD",
      "fallbackToCacheTimeout": 5000,
      "url": "https://u.expo.dev/d47274fa-5fef-47f1-9976-f885ba9f0c10"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.costacoffeeboss.organize",
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "package": "com.costacoffeeboss.organize",
      "adaptiveIcon": {
        "backgroundColor": "#ecdfc8",
        "foregroundImage": "./assets/android-icon-foreground.png",
        "backgroundImage": "./assets/android-icon-background.png",
        "monochromeImage": "./assets/android-icon-monochrome.png"
      }
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "extra": {
      "eas": {
        "projectId": "d47274fa-5fef-47f1-9976-f885ba9f0c10"
      }
    },
    "owner": "costasbowgen",
    "plugins": [
      "./plugins/withLocalOnlyNotifications.js",
      [
        "expo-calendar",
        {
          "calendarPermission": "Organize shows your phone's calendar events alongside its own, read-only."
        }
      ],
      "expo-notifications"
    ]
  }
}
